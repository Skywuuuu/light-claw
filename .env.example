HOST=127.0.0.1
PORT=8000

CODEX_BIN=codex
LIGHT_CLAW_DATA_DIR=.data
LIGHT_CLAW_BASE_DIR=
LIGHT_CLAW_ARCHIVE_ENABLED=true
LIGHT_CLAW_ARCHIVE_DIR=
LIGHT_CLAW_ARCHIVE_INTERVAL_SECONDS=43200
LIGHT_CLAW_INBOUND_MESSAGE_TTL_SECONDS=604800
LIGHT_CLAW_SANDBOX=full-auto
CODEX_SEARCH=false
CODEX_MODEL=
CODEX_TIMEOUT_MIN_SECONDS=180
CODEX_TIMEOUT_MAX_SECONDS=900
CODEX_TIMEOUT_PER_CHAR_MS=80
CODEX_STALL_TIMEOUT_SECONDS=120
LIGHT_CLAW_TASK_HEARTBEAT_ENABLED=true
LIGHT_CLAW_TASK_HEARTBEAT_INTERVAL_SECONDS=1800
LIGHT_CLAW_CRON_ENABLED=true
LIGHT_CLAW_CRON_POLL_INTERVAL_SECONDS=60
LIGHT_CLAW_STATUS_HEARTBEAT_ENABLED=true
LIGHT_CLAW_STATUS_HEARTBEAT_SECONDS=30
DEFAULT_CLI_PROVIDER=codex

FEISHU_ENABLED=true
FEISHU_EVENT_MODE=long_connection
LIGHT_CLAW_AGENTS_FILE=
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
ALLOW_FROM=*
DEFAULT_WORKSPACE_NAME=default

HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
